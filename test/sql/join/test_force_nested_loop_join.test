# name: test/sql/join/test_force_nested_loop_join.test
# description: Test force_nested_loop_join flag forces NL join for all comparison joins
# group: [join]

statement ok
PRAGMA enable_verification

statement ok
CREATE TABLE t1(a INT, b INT);

statement ok
CREATE TABLE t2(c INT, d INT);

statement ok
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30), (4, 40);

statement ok
INSERT INTO t2 VALUES (1, 100), (2, 200), (3, 300), (5, 500);

# Default: equality join uses HASH_JOIN
query II
EXPLAIN SELECT * FROM t1 JOIN t2 ON t1.a = t2.c;
----
physical_plan	<REGEX>:.*HASH_JOIN.*

# Force nested loop join
statement ok
SET force_nested_loop_join=true;

# Now equality join should use NESTED_LOOP_JOIN
query II
EXPLAIN SELECT * FROM t1 JOIN t2 ON t1.a = t2.c;
----
physical_plan	<REGEX>:.*NESTED_LOOP_JOIN[^_].*

# Verify results are still correct
query IIII
SELECT * FROM t1 JOIN t2 ON t1.a = t2.c ORDER BY t1.a;
----
1	10	1	100
2	20	2	200
3	30	3	300

# Test with both flags: force NL + memory optimizations
statement ok
SET operator_memory_optimizations=true;

query II
EXPLAIN SELECT * FROM t1 JOIN t2 ON t1.a = t2.c;
----
physical_plan	<REGEX>:.*NESTED_LOOP_JOIN_OPTIMIZED.*

# Results should still be correct
query IIII
SELECT * FROM t1 JOIN t2 ON t1.a = t2.c ORDER BY t1.a;
----
1	10	1	100
2	20	2	200
3	30	3	300

# Reset and verify it goes back to hash join
statement ok
RESET force_nested_loop_join;

statement ok
RESET operator_memory_optimizations;

query II
EXPLAIN SELECT * FROM t1 JOIN t2 ON t1.a = t2.c;
----
physical_plan	<REGEX>:.*HASH_JOIN.*

# Test LEFT JOIN
statement ok
SET force_nested_loop_join=true;

query II
EXPLAIN SELECT * FROM t1 LEFT JOIN t2 ON t1.a = t2.c;
----
physical_plan	<REGEX>:.*NESTED_LOOP_JOIN.*

query IIII
SELECT * FROM t1 LEFT JOIN t2 ON t1.a = t2.c ORDER BY t1.a;
----
1	10	1	100
2	20	2	200
3	30	3	300
4	40	NULL	NULL

# Test with inequality conditions
statement ok
CREATE TABLE t3 AS SELECT * FROM VALUES (1, 2), (2, 4), (3, 8) t(x, y);

statement ok
CREATE TABLE t4 AS SELECT * FROM VALUES (4), (5) t(z);

# Force NL on inequality join
query II
EXPLAIN SELECT * FROM t3 ANTI JOIN t4 ON t3.x < t4.z AND t3.y < t4.z;
----
physical_plan	<REGEX>:.*NESTED_LOOP_JOIN[^_].*

# With memory optimizations
statement ok
SET operator_memory_optimizations=true;

query II
EXPLAIN SELECT * FROM t3 ANTI JOIN t4 ON t3.x < t4.z AND t3.y < t4.z;
----
physical_plan	<REGEX>:.*NESTED_LOOP_JOIN_OPTIMIZED.*

query II
SELECT * FROM t3 ANTI JOIN t4 ON t3.x < t4.z AND t3.y < t4.z ORDER BY ALL;
----
3	8
