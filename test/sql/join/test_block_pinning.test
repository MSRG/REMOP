#===--------------------------------------------------------------------===//
# Test 9: Edge case - Single row tables
#===--------------------------------------------------------------------===//
statement ok
CREATE TABLE single_row_l(a INT);

statement ok
CREATE TABLE single_row_r(b INT);

statement ok
INSERT INTO single_row_l VALUES (42);

statement ok
INSERT INTO single_row_r VALUES (42);

# Should have no matches since 42 IS DISTINCT FROM 42 = false
query I
SELECT COUNT(*) FROM single_row_l INNER JOIN single_row_r ON single_row_l.a IS DISTINCT FROM single_row_r.b;
----
0

# With different values
statement ok
DELETE FROM single_row_r;

statement ok
INSERT INTO single_row_r VALUES (99);

query II
SELECT * FROM single_row_l INNER JOIN single_row_r ON single_row_l.a IS DISTINCT FROM single_row_r.b;
----
42	99

#===--------------------------------------------------------------------===//
# Test 10: Edge case - Empty tables
#===--------------------------------------------------------------------===//
statement ok
CREATE TABLE empty_pin_l(a INT);

statement ok
CREATE TABLE empty_pin_r(b INT);

query I
SELECT COUNT(*) FROM empty_pin_l INNER JOIN empty_pin_r ON empty_pin_l.a IS DISTINCT FROM empty_pin_r.b;
----
0

query I
SELECT COUNT(*) FROM pin_verify_l INNER JOIN empty_pin_r ON pin_verify_l.a IS DISTINCT FROM empty_pin_r.b;
----
0

query I
SELECT COUNT(*) FROM empty_pin_l INNER JOIN pin_verify_r ON empty_pin_l.a IS DISTINCT FROM pin_verify_r.b;
----
0

#===--------------------------------------------------------------------===//
# Cleanup
#===--------------------------------------------------------------------===//
statement ok
RESET operator_memory_optimizations;

statement ok
DROP TABLE pin_test_left;

statement ok
DROP TABLE pin_test_right;

statement ok
DROP TABLE pin_test_big_left;

statement ok
DROP TABLE pin_test_big_right;

statement ok
DROP TABLE pin_left_outer_l;

statement ok
DROP TABLE pin_left_outer_r;

statement ok
DROP TABLE full_l;

statement ok
DROP TABLE full_r;

statement ok
DROP TABLE pin_nulls_l;

statement ok
DROP TABLE pin_nulls_r;

statement ok
DROP TABLE pin_varchar_l;

statement ok
DROP TABLE pin_varchar_r;

statement ok
DROP TABLE pin_verify_l;

statement ok
DROP TABLE pin_verify_r;

statement ok
DROP TABLE single_row_l;

statement ok
